{
  "version": 2,
  "functions": {
    "server.js": { "runtime": "@vercel/node@3" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" }
  ],
  "headers": [
    {
      "source": "/(index|mobile)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
